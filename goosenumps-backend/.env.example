# Server
PORT=8080
ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=goosenumps
DB_PASSWORD=secret
DB_NAME=goosenumps_db
DB_SSLMODE=disable

# Redis (OTP store)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30

# OTP
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
PASSWORD_RESET_EXPIRY_HOURS=24

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@goosenumps.com
EMAIL_FROM_NAME=Goosenumps

# File Storage (local or s3)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
# AWS_BUCKET=goosenumps-docs
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY=
# AWS_SECRET_KEY=

# Admin seed
ADMIN_EMAIL=admin@goosenumps.com
ADMIN_PASSWORD=Admin@123456
