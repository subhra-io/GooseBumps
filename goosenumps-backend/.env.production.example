PORT=8080
ENV=production

# Neon PostgreSQL (get from neon.tech dashboard)
DB_HOST=ep-xxx-xxx.us-east-1.aws.neon.tech
DB_PORT=5432
DB_USER=goosenumps_owner
DB_PASSWORD=your-neon-password
DB_NAME=goosenumps_db
DB_SSLMODE=require

# Upstash Redis (get from upstash.com dashboard)
REDIS_ADDR=your-redis.upstash.io:6379
REDIS_PASSWORD=your-upstash-password
REDIS_DB=0

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=generate-a-long-random-string-here
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30

# OTP
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
PASSWORD_RESET_EXPIRY_HOURS=24

# Resend (get from resend.com)
RESEND_API_KEY=re_your_real_api_key
EMAIL_FROM=noreply@goosenumps.com
EMAIL_FROM_NAME=Goosenumps

# Cloudflare R2 (get from Cloudflare dashboard)
STORAGE_TYPE=s3
S3_BUCKET=goosenumps-docs
S3_REGION=auto
S3_ACCESS_KEY=your-r2-access-key
S3_SECRET_KEY=your-r2-secret-key
S3_ACCOUNT_ID=your-cloudflare-account-id

# Admin (change these!)
ADMIN_EMAIL=admin@goosenumps.com
ADMIN_PASSWORD=ChangeThisToSomethingStrong!2024
